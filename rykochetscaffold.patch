diff --git a/client/src/ui/screen-manager.ts b/client/src/ui/screen-manager.ts
new file mode 100644
index 0000000..d9e634e
--- /dev/null
+++ b/client/src/ui/screen-manager.ts
@@ -0,0 +1,18 @@
+export type ScreenName = 'login' | 'menu';
+
+export class ScreenManager {
+  private current: ScreenName | null = null;
+
+  show(name: ScreenName): void {
+    const screens = document.querySelectorAll<HTMLElement>('.screen');
+    screens.forEach((el) => {
+      const isTarget = el.dataset['screen'] === name;
+      el.hidden = !isTarget;
+    });
+    this.current = name;
+  }
+
+  getCurrent(): ScreenName | null {
+    return this.current;
+  }
+}
